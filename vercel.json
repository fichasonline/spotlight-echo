{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemaps/pages.xml",
      "destination": "/api/sitemap-pages"
    },
    {
      "source": "/sitemaps/articles.xml",
      "destination": "/api/sitemap-articles"
    },
    {
      "source": "/sitemaps/events.xml",
      "destination": "/api/sitemap-events"
    },
    {
      "source": "/news-sitemap.xml",
      "destination": "/api/news-sitemap"
    },
    {
      "source": "/sitemaps/salas.xml",
      "destination": "/api/sitemap-salas"
    },
    {
      "source": "/rss.xml",
      "destination": "/api/rss"
    },
    {
      "source": "/noticias/:slug",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|whatsapp|telegrambot|googlebot|bingbot|applebot|discordbot|vkshare|pinterest|tumblr|redditbot|embedly|quora|outbrain|w3c_validator|skypeuripreview|nuzzel).*" }],
      "destination": "/api/og-render"
    },
    {
      "source": "/eventos/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|whatsapp|telegrambot|googlebot|bingbot|applebot|discordbot|vkshare|pinterest|tumblr|redditbot|embedly|quora|outbrain|w3c_validator|skypeuripreview|nuzzel).*" }],
      "destination": "/api/og-render"
    },
    {
      "source": "/salas/:slug",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|whatsapp|telegrambot|googlebot|bingbot|applebot|discordbot|vkshare|pinterest|tumblr|redditbot|embedly|quora|outbrain|w3c_validator|skypeuripreview|nuzzel).*" }],
      "destination": "/api/og-render"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
